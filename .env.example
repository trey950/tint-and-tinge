# Tint & Tinge — Environment variables
# Copy to .env locally, set in Render dashboard for production.

# Server
NODE_ENV=production
PORT=3000
APP_URL=https://tintandtinge.com

# Stripe (live mode)
STRIPE_SECRET_KEY=sk_live_xxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx
STRIPE_PRICE_ID=price_xxxxxxxx          # $49 one-time product price in Stripe

# Resend
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM=hello@tintandtinge.com
RESEND_REPLY_TO=hello@tintandtinge.com

# Meta Pixel
META_PIXEL_ID=                          # Add Pixel ID when ready (e.g. 1234567890123456)

# Business (for legal pages + email footer)
BUSINESS_NAME=Tint and Tinge
BUSINESS_ADDRESS=193 Westbury Circle, Folsom, CA 95630
BUSINESS_